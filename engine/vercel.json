{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["syd1"],
  "functions": {
    "api/index.py": { "maxDuration": 60, "includeFiles": "assets/**" }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api/index.py" }],
  "crons": [{ "path": "/sanctions/cron-refresh", "schedule": "0 17 * * 1" }]
}
