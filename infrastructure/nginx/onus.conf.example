# Example nginx reverse proxy for an Onus production deployment.
#
# Responsibilities the app delegates to the edge (see the README hardening checklist):
#   - TLS termination + HSTS
#   - rate limiting that sees real client IPs (the app's login throttle is per-account;
#     this protects against volumetric abuse and signup farming)
#
# Copy to your nginx conf.d, set the server_name and certificate paths, and reload.
# Caddy (automatic HTTPS) or a cloud load balancer with a WAF are fine alternatives;
# the key points are TLS, HSTS, and an IP-based rate limit on the auth endpoints.

# Rate-limit buckets keyed on client IP. Tune to your traffic.
limit_req_zone $binary_remote_addr zone=onus_auth:10m rate=5r/m;    # login / signup
limit_req_zone $binary_remote_addr zone=onus_general:10m rate=20r/s; # everything else

server {
    listen 80;
    server_name onus.example.com.au;
    # Redirect all plain HTTP to HTTPS.
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name onus.example.com.au;

    ssl_certificate     /etc/ssl/onus/fullchain.pem;
    ssl_certificate_key /etc/ssl/onus/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    client_max_body_size 25m;  # allow document/evidence uploads (engine caps at 20 MB)

    # Tighter limit on the credential endpoints (next-auth handles login under /api/auth).
    location /api/auth/ {
        limit_req zone=onus_auth burst=10 nodelay;
        proxy_pass http://web:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Everything else -> the Next.js web tier (which proxies to the engine server-side).
    location / {
        limit_req zone=onus_general burst=40 nodelay;
        proxy_pass http://web:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # The engine (:8000) and database are never exposed directly - only the web tier is.
}
